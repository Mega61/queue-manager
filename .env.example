# ─────────────────────────────────────────────────────────────────────────────
# Andante Labs Queue Manager — environment configuration
# Copy to `.env` and adjust. Only NON-SECRET operational settings live here.
#
# Broker credentials (URL, VPN, username, password, queue/topic) are entered in
# the UI per session and are NEVER stored in this file or on the server.
# ─────────────────────────────────────────────────────────────────────────────

# Next.js server
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info          # error | warn | info | debug
LOG_JSON=true           # true → single-line JSON logs (journald/log shippers)

# In-memory received-message ring buffer
MESSAGE_BUFFER_SIZE=1000

# ── Resilience tuning (non-secret; safe defaults, override only if needed) ───
SOLACE_CONNECT_RETRIES=5            # initial connect attempts (-1 = forever)
SOLACE_RECONNECT_RETRIES=-1        # reconnect attempts after a drop (-1 = forever)
SOLACE_RECONNECT_WAIT_MS=3000
SOLACE_CONNECT_TIMEOUT_MS=10000
SOLACE_KEEPALIVE_MS=3000
SOLACE_KEEPALIVE_LIMIT=10
SOLACE_CONSUMER_RECONNECT=-1       # queue-flow rebind attempts (-1 = forever)
SOLACE_CONSUMER_RECONNECT_WAIT_MS=3000
SOLACE_PUBLISH_ACK_TIMEOUT_MS=10000
